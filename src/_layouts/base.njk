<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="{{ description or 'A fan blog about Symboli Rudolf in Umamusume Pretty Derby.' }}" />
  <meta name="theme-color" content="#7fc4e8" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=M+PLUS+Rounded+1c:wght@400;500;700&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=M+PLUS+Rounded+1c:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/assets/css/main.css" />
  <title>{% if title %}{{ title }} — Symboli Rudolf{% else %}Symboli Rudolf — 皇帝{% endif %}</title>
</head>
<body>

<a class="skip-link" href="#main-content">Skip to content</a>

<div class="sky" aria-hidden="true"></div>

<header class="topbar">
  <a class="brand" href="/" aria-label="Symboli Rudolf — home">
    <img class="brand-chibi" src="/assets/rudolf_chibi.webp" alt="" aria-hidden="true" width="52" height="65" />
    <span class="brand-en">Symboli Rudolf</span>
  </a>
</header>

<main id="main-content">
  {{ content | safe }}
</main>

<footer class="footer">
  <div class="skyline" aria-hidden="true">
    <div class="skyline-buildings">
      <span class="bld b1"></span>
      <span class="bld b2"></span>
      <span class="bld b3"></span>
      <span class="bld b4"></span>
      <span class="bld b5"></span>
      <span class="bld b6"></span>
      <span class="bld b7"></span>
      <span class="bld b8"></span>
      <span class="bld b9"></span>
      <span class="bld b10"></span>
      <span class="bld b11"></span>
      <span class="bld b12"></span>
    </div>
    <div class="skyline-ground"></div>
  </div>
  <div class="footer-text">
    <span>Symboli Rudolf</span>
    <span class="footer-note">Fan site · not affiliated with Cygames</span>
  </div>
</footer>

<script src="/assets/js/nav.js"></script>
</body>
</html>
